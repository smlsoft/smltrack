# ====================================
# OpenClaw Mini CRM Environment Variables
# ====================================
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง:
#   copy .env.example .env
#
# ห้าม commit ไฟล์ .env ขึ้น Git!
# ====================================

# === MongoDB Atlas ===
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=Cluster0

# === LINE Messaging API ===
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# === AI Providers (สมัครฟรี) ===
SAMBANOVA_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=

# === MCP ERP (เว้นว่างถ้าไม่ใช้) ===
MCP_ERP_API_KEY=

# === Cloudflare Tunnel ===
CLOUDFLARE_TUNNEL_TOKEN=

# === OpenClaw AI Advisor ===
OPENCLAW_GATEWAY_TOKEN=
# สร้างด้วย: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"

# === Telegram Bot (น้องกุ้ง) ===
TELEGRAM_BOT_TOKEN=
# สร้าง bot ผ่าน @BotFather แล้วใส่ token ที่นี่
# หลัง deploy แล้ว setup webhook ที่: https://crm.satistang.com/setup-telegram-webhook

# === Dashboard Config Password ===
CONFIG_PASSWORD=
