# ====================================
# SMLTrack Environment Variables
# ====================================
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง:
#   copy .env.example .env
#
# ห้าม commit ไฟล์ .env ขึ้น Git!
# ====================================

# === MongoDB Atlas ===
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?appName=Cluster0

# === LINE Messaging API ===
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# === AI Providers (สมัครฟรี) ===
SAMBANOVA_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_API_KEY=

# === MCP ERP (เว้นว่างถ้าไม่ใช้) ===
MCP_ERP_API_KEY=

# === Cloudflare Tunnel ===
CLOUDFLARE_TUNNEL_TOKEN=

# === Dashboard Config Password ===
CONFIG_PASSWORD=
